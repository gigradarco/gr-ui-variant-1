# Copy into `.env` for local development or set in Vercel.

VITE_APP_NAME=GigRadar

# API target: local | cloud (omit for legacy: only VITE_API_BASE_URL)
VITE_API_MODE=local
# Used when VITE_API_MODE=local. Omit this key (recommended) or use VITE_API_LOCAL_URL= for Vite proxy —
# same host as the UI (http://localhost:5173), which avoids CORS and OAuth cookie/host mismatches.
# Set only if you need to call the Worker directly, e.g. VITE_API_LOCAL_URL=http://127.0.0.1:8787
# VITE_API_LOCAL_URL=
# Used when VITE_API_MODE=cloud
VITE_API_CLOUD_URL=https://gr-backend-dev.gigradar.workers.dev

# Legacy (if VITE_API_MODE unset): empty = Vite proxy; else full Worker URL.
# VITE_API_BASE_URL=
VITE_ENABLE_DEMO_MODE=true

# Auth runs through gr-backend (`/api/auth/*`); Supabase keys stay on the server only.
# Google sign-in (local): add Supabase Redirect URLs for your API callback host, e.g.
#   http://localhost:5173/api/auth/callback  (Vite proxy)
#   http://127.0.0.1:8787/api/auth/callback  (VITE_API_LOCAL_URL direct)
# Leave AUTH_CALLBACK_ORIGIN unset in gr-backend/.dev.vars for local — see gr-backend/.dev.vars.example.

# OpenAI (server-side only; do not expose in frontend code)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional: Vercel serverless proxies. Local dev: Mapbox goes through gr-backend — use /api/geocode (Vite proxy).
VITE_OPENAI_PROXY_URL=/api/openai-recommend
VITE_MAPBOX_PROXY_URL=/api/geocode

# Mapbox (server-side preferred)
MAPBOX_ACCESS_TOKEN=
