# Copy these keys into Vercel Project Settings -> Environment Variables.
# For local development, duplicate this file as `.env` and fill values.

VITE_APP_NAME=GigRadar
VITE_API_BASE_URL=https://api.example.com
VITE_PUBLIC_MAPBOX_TOKEN=
VITE_ENABLE_DEMO_MODE=true

# OpenAI (server-side only; do not expose in frontend code)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional: frontend calls your backend/proxy endpoint
VITE_OPENAI_PROXY_URL=/api/openai-recommend
VITE_MAPBOX_PROXY_URL=/api/mapbox-geocode

# Mapbox (server-side preferred)
MAPBOX_ACCESS_TOKEN=
